# Backend
SECRET_KEY=change-me
DATABASE_URL=sqlite+aiosqlite:///./starva.db
CORS_ORIGINS=http://localhost:5173
ACCESS_TOKEN_EXPIRES_MINUTES=30
REFRESH_TOKEN_EXPIRES_MINUTES=43200
SENTRY_DSN=
METRICS_ENABLED=true
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RPM=120

# Frontend dev — Vite proxies /api to this backend (see vite.config.ts)
VITE_BACKEND_URL=http://127.0.0.1:8002

# Optional: direct axios base URL (skip proxy). Must include /api suffix:
# VITE_API_BASE_URL=http://127.0.0.1:8002/api


